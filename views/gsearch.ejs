<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>ScreenHive</title>
    <script src="https://cdn.jsdelivr.net/npm/@tailwindcss/browser@4"></script>
    <style type="text/tailwindcss">
@theme {
    --color-page: #0D1117;
    --color-surface: #161B22;
    --color-hover: #21262D;
    --color-border: #30363D;
    --color-accent: #2F81F7;
    --color-accent-hover: #1F6FEB;
    --color-text: #E6EDF3;
    --color-muted: #8B949E;
    --color-subtle: #6E7681;
    --color-done: #3FB950;
    --color-danger: #F85149;
    --color-pin: #E3B341;
    --color-pin-hover: #D29922;
    --color-show: #58A6FF;
    --color-show-hover: #79C0FF;
}
    </style>
</head>
<body class="min-h-screen bg-page text-text ">

    
    <nav class="flex justify-between items-center px-8 py-2 bg-surface border-b border-border w-full ">
        <div class="flex items-center gap-3">
            <img class=" rounded-lg w-15 h-15 object-cover object-centers" src="/gifs/screen_hive_loader.gif">
            <h1 class="text-lg font-semibold tracking-tight text-text">Movieplex</h1>
        </div>
       <div class="flex-1 flex justify-center px-8">
    <form action="/search" method="/GET" class="w-full max-w-md flex">
        <input type="text" placeholder="Search movies, shows..." name="q" 
        class="w-full max-w-md px-4 py-2 rounded-lg bg-page border border-border text-text text-sm placeholder-subtle focus:outline-none focus:border-purple-600 transition-colors">
        <input type="submit" class="p-1 rounded-lg border border-border bg-blue-600 hover:bg-purple-600 transition-all value="submit"></form>
</div>
        <div class="flex gap-1">
            <%if(user){%>
                <h1 class="text-text font-bold text-md tracking-tighter">Welcome,<%=user.name%>👋</h1>
                <a href="/logout" class="px-4 py-2 rounded-lg text-sm font-medium text-muted hover:bg-danger hover:text-text transition-colors duration-150">Logout</a>
                <a href="/profile" class="px-4 py-2 rounded-lg text-sm font-medium text-muted hover:bg-purple-600 hover:text-text transition-colors duration-150"><%=user.username%></a>
                <%}else{%>
                    <a href="/login" class="px-4 py-2 rounded-lg text-sm font-medium text-muted hover:bg-blue-600 hover:text-text transition-colors duration-150">login</a>
                    <%}%>
            
            <a href="/" class="px-4 py-2 rounded-lg text-sm font-medium text-muted hover:bg-hover hover:text-text transition-colors duration-150">Home</a>
        </div>
    </nav>


      <div class="flex gap-2 justify-center mt-1">
      <% gens2.forEach(function(v){%>
                <a href="/gsearch/<%=v.id%>"><div class="p-3 bg-surface/50 border border-border rounded-lg hover:scale-105 transition-all hover:border-purple-600"><h1 class="font-bold text-md italic "><%=v.name%></h1></div></a>
              <%});%>
    </div>


    <div class="w-1/4 mt-5 bg-surface border border-border"><h1 class="text-text font-bold text-5xl text-center tracking-tight italic rounded-lg"><%=gtitle%> </h1></div>
   
<div class="flex flex-wrap justify-center gap-6 mt-5">
    <%m.forEach(function(movie){ %>
 <div class="flex gap-3 w-full max-w-sm md:max-w-md justify-center mt-6 px-5">
   <a href="/mdetails/<%=movie.id%>">
     <div class=" h-full flex flex-col bg-surface border border-border rounded-xl p-5 hover:scale-105 transition-all duration-320 outline outline-2 outline-transparent hover:outline-purple-600">

        <div class="w-full aspect-square overflow-hidden rounded-lg border border-border">
             <%if(movie.poster_path){%>
            <img src="https://image.tmdb.org/t/p/w500<%= movie.poster_path %>" class="w-full h-full object-cover object-center" >
            <%}else{%>
                <img src="/images/pngtree-no-image-available-icon-flatvector-illustration-pic-design-profile-vector-png-image_40966566.jpg" class="w-full h-full object-cover object-center">
                <%}%>
        </div>

        <h3 class="mt-4 text-xl font-semibold text-white italic">
           <%= movie.title %>
        </h3>

        <p class="text-sm text-zinc-500 break-normal tracking-tighter line-clamp-3">
           <%=movie.overview%>
            
        </p>

        <div class="mt-6 flex flex-col sm:flex-row gap-3">
            <%if (movie.vote_average == 0){%>
                     <h1 class="flex text-center rounded-lg text-green-600 py-2  transition">Not Rated yet</h1>
                     <%}else{%>
                         <h1 class="flex text-center rounded-lg text-green-600 py-2  transition">⭐<%=movie.vote_average.toFixed(1)%></h1>
                         <%}%>
           <%if (todaysdate< new Date(movie.release_date)){%>
                     <h2 class="flex-1 text-center rounded-lg text-white-600 py-2 transition ">Release status:<span class=" font-bold">Coming soon..</span> </h2>
                     <%}else{%>
                         <h1 class="flex-1 text-center rounded-lg text-white-600 py-2 transition" >Released on:<span class="  font-bold "><%=movie.release_date%></span></h1>
                         <%}%>
        
        </div>

    </div>
    </a>
</div>

    
<% });%>
</div>
<div class="flex justify-center items-center gap-3 mt-2">
    <%if(page>1){%>
     <a href="/search?q=<%=useableq%>&page=<%= page - 1 %>" class="px-4 py-2 rounded-lg text-sm font-medium text-muted hover:bg-blue-600 hover:text-text transition-colors duration-150">Prev</a>
     <%}%>
     <%if(page<n){%>
      <a href="/search?q=<%=useableq%>&page=<%= page + 1 %>" class="px-4 py-2 rounded-lg text-sm font-medium text-muted hover:bg-blue-600 hover:text-text transition-colors duration-150">Next</a>
      <%}%>
      </div>
      <h1 class="text-xl font-semibold text-white text-center p-2 italic">Currently on page-<%=page%></h1>

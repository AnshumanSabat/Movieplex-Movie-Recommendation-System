<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>ScreenHive</title>
    <script src="https://cdn.jsdelivr.net/npm/@tailwindcss/browser@4"></script>
    <style type="text/tailwindcss">
@theme {
    --color-page: #0D1117;
    --color-surface: #161B22;
    --color-hover: #21262D;
    --color-border: #30363D;
    --color-accent: #2F81F7;
    --color-accent-hover: #1F6FEB;
    --color-text: #E6EDF3;
    --color-muted: #8B949E;
    --color-subtle: #6E7681;
    --color-done: #3FB950;
    --color-danger: #F85149;
    --color-pin: #E3B341;
    --color-pin-hover: #D29922;
    --color-show: #58A6FF;
    --color-show-hover: #79C0FF;
}
    </style>
</head>
<body class="min-h-screen bg-page text-text ">

    
    <nav class="flex justify-between items-center px-8 py-2 bg-surface border-b border-border w-full ">
        <div class="flex items-center gap-3">
          <img class=" rounded-lg w-15 h-15 object-cover object-centers" src="/gifs/screen_hive_loader.gif">
            <h1 class="text-lg font-semibold tracking-tight text-text">Movieplex</h1>
        </div>
        <div class="flex gap-1">
            <%if(user){%>
                <a href="/logout" class="px-4 py-2 rounded-lg text-sm font-medium text-muted hover:bg-danger hover:text-text transition-colors duration-150">Logout</a>
                <a href="/profile" class="px-4 py-2 rounded-lg text-sm font-medium text-muted hover:bg-purple-600 hover:text-text transition-colors duration-150"><%=user.username%></a>
                <%}else{%>
                    <a href="/login" class="px-4 py-2 rounded-lg text-sm font-medium text-muted hover:bg-blue-600 hover:text-text transition-colors duration-150">login</a>
                    <%}%>
            
            <a href="/" class="px-4 py-2 rounded-lg text-sm font-medium text-muted hover:bg-hover hover:text-text transition-colors duration-150">Home</a>
        </div>
    </nav>
    <h1 class="font-extrabold text-text text-center text-5xl">User Details</h1>
    <div class="flex justify-center items-center w-full mt-5 ">
        
           <div class=" flex flex-col h-full rounded-lg border border-border bg-surface/60 w-full max-w-xl">
            <%if(user.name){%>
            <h1 class="font-bold" >Name:<span class="text-danger text-3xl font-extrabold p-4"><%=user.name%></span></h1>
            <%}%>
            <h1 class="font-bold" >Username:<span class="text-danger text-3xl font-extrabold p-4"><%=user.username%></span></h1>
              <%if(user.email){%>
            <h1 class="font-bold" >Email:<span class="text-danger text-3xl font-extrabold p-4 "><%=user.email%></span></h1>
            <%}%>
             <%if(user.age){%>
           <h1 class="font-bold" >Age:<span class="text-danger text-3xl font-extrabold p-4"><%=user.age%></span></h1>
            <%}%>
            
            
            </div>

        </div>
</body>
</html>
